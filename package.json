{
  "name": "echo-salvage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server": "node server/server.js",
    "test:gameplay": "node --test scripts/gameplay-reliability.test.js",
